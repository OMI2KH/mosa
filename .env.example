# 🎯 MOSA FORGE: Enterprise Environment Configuration
# 
# 🏗️ PRODUCTION-READY ENVIRONMENT TEMPLATE
# @version 1.0.0
# @author Oumer Muktar | Powered by Chereka
#
# 🚀 DEPLOYMENT INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in actual values (DO NOT COMMIT .env)
# 3. Use environment-specific files for staging/production
#

# ========================
# 🏗️ APPLICATION CONFIGURATION
# ========================

# 🎯 Core Application Settings
NODE_ENV=production
APP_NAME="Mosa Forge Enterprise"
APP_VERSION=1.0.0
APP_PORT=3000
APP_HOST=0.0.0.0
APP_URL=https://api.mosaforge.com
CLIENT_URL=https://app.mosaforge.com
ADMIN_URL=https://admin.mosaforge.com

# 🏗️ Instance & Cluster Configuration
INSTANCE_ID=mosa-forge-prod-01
CLUSTER_NAME=mosa-forge-enterprise-cluster
REGION=eu-central-1
DEPLOYMENT_TIER=enterprise

# 🔐 Security & Encryption
APP_SECRET=change_this_in_production_with_64_char_minimum_secure_key
JWT_SECRET=change_this_jwt_secret_with_64_char_minimum_secure_key
ENCRYPTION_KEY=32_byte_encryption_key_for_data_protection
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# ========================
# 🗃️ DATABASE CONFIGURATION
# ========================

# 🏗️ PostgreSQL Primary Database
DATABASE_URL=postgresql://username:password@localhost:5432/mosa_forge_enterprise
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mosa_forge_enterprise
DB_USERNAME=mosa_forge_user
DB_PASSWORD=change_this_secure_database_password
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_LOGGING=false

# 🏗️ Read Replica (Production)
DB_READ_HOST=read-replica.mosaforge.com
DB_READ_PORT=5432
DB_READ_NAME=mosa_forge_enterprise_read
DB_READ_USERNAME=mosa_forge_read_user
DB_READ_PASSWORD=change_this_secure_read_password

# 🔄 Redis Cache & Session Store
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_this_secure_redis_password
REDIS_DB=0
REDIS_KEY_PREFIX=mosa_forge_prod
REDIS_TLS=true

# 🏗️ Redis Cluster (Production)
REDIS_CLUSTER_HOSTS=redis-cluster-1:6379,redis-cluster-2:6379,redis-cluster-3:6379
REDIS_SENTINEL_HOSTS=sentinel-1:26379,sentinel-2:26379,sentinel-3:26379
REDIS_SENTINEL_MASTER=master01

# ========================
# 💰 PAYMENT CONFIGURATION
# ========================

# 🎯 Revenue Split Configuration
BUNDLE_PRICE=1999
MOSA_REVENUE=1000
EXPERT_REVENUE=999
PAYOUT_SCHEDULE=333,333,333
QUALITY_BONUS_RATE=0.2

# 🏦 Telebirr Payment Gateway
TELEBIRR_BASE_URL=https://api.telebirr.com/v1
TELEBIRR_MERCHANT_ID=your_telebirr_merchant_id
TELEBIRR_PUBLIC_KEY=telebirr_public_key_here
TELEBIRR_PRIVATE_KEY=telebirr_private_key_here
TELEBIRR_CALLBACK_URL=https://api.mosaforge.com/v1/payments/telebirr/callback

# 🏦 CBE Birr Payment Gateway
CBE_BIRR_BASE_URL=https://api.cbebirr.com/v1
CBE_BIRR_MERCHANT_ID=your_cbe_birr_merchant_id
CBE_BIRR_API_KEY=cbe_birr_api_key_here
CBE_BIRR_SECRET_KEY=cbe_birr_secret_key_here
CBE_BIRR_CALLBACK_URL=https://api.mosaforge.com/v1/payments/cbe-birr/callback

# 💸 Payment Security
PAYMENT_WEBHOOK_SECRET=payment_webhook_secret_for_verification
PAYMENT_TIMEOUT=300000
PAYMENT_RETRY_ATTEMPTS=3

# ========================
# 🔐 AUTHENTICATION & SECURITY
# ========================

# 🆔 Fayda ID Government Integration
FAYDA_BASE_URL=https://api.fayda.gov.et/v1
FAYDA_API_KEY=your_fayda_government_api_key
FAYDA_SECRET_KEY=your_fayda_government_secret
FAYDA_VERIFICATION_URL=https://api.fayda.gov.et/v1/verify
FAYDA_CALLBACK_URL=https://api.mosaforge.com/v1/auth/fayda/callback

# 📱 OTP Configuration
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_ATTEMPTS_LIMIT=5
OTP_RESEND_COOLDOWN=60

# 📧 SMS Gateway (Ethio Telecom)
ETHIO_TELECOM_SMS_URL=https://sms.ethiotelecom.et/api/v1/send
ETHIO_TELECOM_API_KEY=ethio_telecom_sms_api_key
ETHIO_TELECOM_SENDER_ID=MosaForge

# ✉️ Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@mosaforge.com
SENDGRID_FROM_NAME="Mosa Forge"
EMAIL_TEMPLATE_VERIFICATION=email_verification_template_id
EMAIL_TEMPLATE_WELCOME=welcome_email_template_id

# ========================
# 🛡️ QUALITY GUARANTEE SYSTEM
# ========================

# 🎯 Quality Thresholds
QUALITY_THRESHOLD=4.0
COMPLETION_RATE_THRESHOLD=0.7
RESPONSE_TIME_THRESHOLD=24
SATISFACTION_THRESHOLD=0.8
AUTO_ENFORCEMENT_ENABLED=true

# 🏆 Expert Tier Configuration
MASTER_TIER_THRESHOLD=4.7
SENIOR_TIER_THRESHOLD=4.3
STANDARD_TIER_THRESHOLD=4.0
DEVELOPING_TIER_THRESHOLD=3.5

# 📊 Capacity Limits
MASTER_TIER_CAPACITY=9999
SENIOR_TIER_CAPACITY=100
STANDARD_TIER_CAPACITY=50
DEVELOPING_TIER_CAPACITY=25
PROBATION_TIER_CAPACITY=10

# ========================
# 🎓 LEARNING ENGINE CONFIG
# ========================

# 📚 Duolingo-style Learning
LEARNING_ENGINE_BASE_URL=https://learning.mosaforge.com
EXERCISE_GENERATION_ENABLED=true
REALTIME_CHARTS_ENABLED=true
PROGRESS_TRACKING_INTERVAL=3600

# ⏱️ Phase Durations (in days)
MINDSET_PHASE_DURATION=28
THEORY_PHASE_DURATION=60
HANDS_ON_PHASE_DURATION=60
CERTIFICATION_PHASE_DURATION=14

# ========================
# 🤖 INTEGRATION SERVICES
# ========================

# 🏆 Yachi Platform Integration
YACHI_BASE_URL=https://api.yachi.com/v1
YACHI_API_KEY=your_yachi_platform_api_key
YACHI_PARTNER_ID=mosa_forge_partner_id
YACHI_CALLBACK_URL=https://api.mosaforge.com/v1/certification/yachi/callback

# 📊 Analytics & Monitoring
MIXPANEL_TOKEN=your_mixpanel_token_for_analytics
SENTRY_DSN=your_sentry_dsn_for_error_tracking
LOG_LEVEL=info

# 🌐 CDN & File Storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-central-1
S3_BUCKET_NAME=mosa-forge-enterprise
S3_UPLOAD_URL=https://files.mosaforge.com
CDN_BASE_URL=https://cdn.mosaforge.com

# ========================
# 🏗️ MICROSERVICES CONFIG
# ========================

# 🔌 Service Discovery & Communication
SERVICE_DISCOVERY_URL=https://discovery.mosaforge.com
API_GATEWAY_URL=https://gateway.mosaforge.com
SERVICE_MESH_ENABLED=true

# 📡 Internal Service Endpoints
AUTH_SERVICE_URL=https://auth.mosaforge.com
PAYMENT_SERVICE_URL=https://payment.mosaforge.com
EXPERT_SERVICE_URL=https://expert.mosaforge.com
STUDENT_SERVICE_URL=https://student.mosaforge.com
QUALITY_SERVICE_URL=https://quality.mosaforge.com
LEARNING_SERVICE_URL=https://learning.mosaforge.com
TRAINING_SERVICE_URL=https://training.mosaforge.com
CERTIFICATION_SERVICE_URL=https://certification.mosaforge.com
ANALYTICS_SERVICE_URL=https://analytics.mosaforge.com

# 🔐 Service-to-Service Authentication
INTERNAL_API_KEY=internal_service_to_service_secure_api_key
SERVICE_JWT_SECRET=service_jwt_secret_for_internal_communication

# ========================
# 📊 MONITORING & OBSERVABILITY
# ========================

# 📈 Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_PREFIX=mosa_forge

# 📝 ELK Stack Logging
ELASTICSEARCH_URL=https://elasticsearch.mosaforge.com
ELASTICSEARCH_USERNAME=elastic_user
ELASTICSEARCH_PASSWORD=elastic_password
LOGSTASH_URL=https://logstash.mosaforge.com
KIBANA_URL=https://kibana.mosaforge.com

# 🚨 Alerting & Notifications
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_integration_key

# ========================
# 🐳 CONTAINER & ORCHESTRATION
# ========================

# 🏗️ Kubernetes Configuration
KUBERNETES_NAMESPACE=mosa-forge-production
KUBERNETES_CLUSTER=eks-mosa-forge-cluster
POD_MEMORY_LIMIT=512Mi
POD_CPU_LIMIT=500m

# 🔧 Docker Configuration
DOCKER_REGISTRY=registry.mosaforge.com
DOCKER_IMAGE_PREFIX=mosa-forge
DOCKER_TAG=latest

# ========================
# 🔄 RATE LIMITING & THROTTLING
# ========================

# 🚦 API Rate Limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_FAILED_REQUESTS=false

# 🔐 Authentication Rate Limits
AUTH_RATE_LIMIT_WINDOW=15
AUTH_RATE_LIMIT_MAX=5
PAYMENT_RATE_LIMIT_WINDOW=60
PAYMENT_RATE_LIMIT_MAX=10

# ========================
# 🛠️ DEVELOPMENT & DEBUGGING
# ========================

# 🔍 Debugging & Troubleshooting
DEBUG_ENABLED=false
DEBUG_NAMESPACE=mosa-forge:*
QUERY_LOGGING_ENABLED=false
TRACE_REQUESTS_ENABLED=false

# 🧪 Testing Configuration
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/mosa_forge_test
TEST_REDIS_URL=redis://localhost:6379/1
TEST_TIMEOUT=30000

# ========================
# 🌍 REGIONAL CONFIGURATION
# ========================

# 🇪🇹 Ethiopia Specific Settings
DEFAULT_LANGUAGE=am
DEFAULT_CURRENCY=ETB
DEFAULT_TIMEZONE=Africa/Addis_Ababa
SUPPORTED_LANGUAGES=am,en
SUPPORTED_CURRENCIES=ETB

# 📞 Support & Contact
SUPPORT_PHONE=+251-XXX-XXX-XXX
SUPPORT_EMAIL=support@mosaforge.com
LEGAL_EMAIL=legal@mosaforge.com
ENTERPRISE_EMAIL=enterprise@mosaforge.com

# ========================
# 🔒 SECURITY & COMPLIANCE
# ========================

# 🛡️ Security Headers
CSP_ENABLED=true
HSTS_ENABLED=true
CORS_ORIGINS=https://app.mosaforge.com,https://admin.mosaforge.com
CORS_CREDENTIALS=true

# 📄 Compliance & Legal
PRIVACY_POLICY_URL=https://mosaforge.com/privacy
TERMS_OF_SERVICE_URL=https://mosaforge.com/terms
DATA_RETENTION_DAYS=1095

# ========================
# 🚀 PERFORMANCE & OPTIMIZATION
# ========================

# ⚡ Performance Tuning
QUERY_TIMEOUT=30000
CONNECTION_TIMEOUT=10000
REQUEST_TIMEOUT=30000
COMPRESSION_ENABLED=true
CACHE_TTL=3600

# 🔄 Background Jobs
JOB_RETRY_ATTEMPTS=3
JOB_RETRY_DELAY=5000
CRON_ENABLED=true

# ========================
# 📱 MOBILE APP CONFIGURATION
# ========================

# 📲 React Native App
APP_SCHEME=mosaforge
APP_STORE_ID=123456789
PLAY_STORE_ID=com.mosaforge.app
EXPO_PROJECT_ID=your_expo_project_id

# 🔔 Push Notifications
FCM_SERVER_KEY=your_firebase_cloud_messaging_key
APN_KEY_ID=your_apple_push_notification_key_id
APN_TEAM_ID=your_apple_developer_team_id

# ========================
# 🎯 BUSINESS INTELLIGENCE
# ========================

# 📊 Analytics & Reporting
ANALYTICS_ENABLED=true
REPORTING_TIMEZONE=Africa/Addis_Ababa
BUSINESS_DAY_START=06:00
BUSINESS_DAY_END=20:00

# 💰 Financial Reporting
TAX_RATE=0.15
REVENUE_RECOGNITION_ENABLED=true
AUTO_INVOICING_ENABLED=true

# ========================
# 🆘 EMERGENCY & MAINTENANCE
# ========================

# 🚨 Emergency Mode
MAINTENANCE_MODE_ENABLED=false
EMERGENCY_MODE_ENABLED=false
READ_ONLY_MODE_ENABLED=false

# 🔧 System Maintenance
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ========================
# 🔐 SECRETS & ENCRYPTION (PRODUCTION ONLY)
# ========================

# 🗝️ Production Secrets (DO NOT USE DEFAULTS)
# These must be set in production environment
PRODUCTION_SECRET_KEY=must_be_set_in_actual_production
PRODUCTION_JWT_SECRET=must_be_set_in_actual_production
PRODUCTION_ENCRYPTION_KEY=must_be_set_in_actual_production

# ========================
# 🏁 DEPLOYMENT CHECKLIST
# ========================

# ✅ Pre-Deployment Validation
VALIDATE_CONFIG=true
CHECK_DEPENDENCIES=true
RUN_MIGRATIONS=true
SEED_REQUIRED_DATA=true

# 🔄 Zero-Downtime Deployment
HEALTH_CHECK_ENDPOINT=/health
READINESS_CHECK_ENDPOINT=/ready
LIVENESS_CHECK_ENDPOINT=/live

# ========================
# 📝 CONFIGURATION NOTES
# ========================

# 💡 IMPORTANT:
# 1. NEVER commit actual .env files to version control
# 2. Use environment-specific files: .env.production, .env.staging
# 3. Use secret management service for production
# 4. Rotate secrets regularly
# 5. Monitor for configuration changes

# 🏗️ Enterprise Security Compliance:
# - All passwords must be 16+ characters with complexity
# - API keys must be rotated every 90 days
# - Database connections must use SSL/TLS
# - Regular security audits required

# 📞 Support:
# For configuration assistance, contact: devops@mosaforge.com