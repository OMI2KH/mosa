# =============================================
# 🚀 MOSA FORGE - ENTERPRISE ENVIRONMENT CONFIG
# Production-Ready Environment Variables
# =============================================
# Powered by Chereka | Founded by Oumer Muktar
# =============================================

# =======================
# 🎯 APPLICATION CONFIG
# =======================
NODE_ENV=production
APP_NAME=MosaForge-Enterprise
APP_VERSION=1.0.0
PLATFORM_REGION=ethiopia
INSTANCE_ID=mosaforge-prod-001

# =======================
# 🌐 SERVER CONFIGURATION
# =======================
PORT=443
HOST=0.0.0.0
API_GATEWAY_PORT=8443
API_PREFIX=/api/v1
CORS_ORIGIN=https://app.mosaforge.com,https://admin.mosaforge.com
TRUST_PROXY=1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# =======================
# 🗃️ DATABASE CONFIGURATION
# =======================

# PostgreSQL Primary Cluster
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=require&pool_timeout=30&connection_limit=20
DB_HOST=mosaforge-cluster.prod.ethiopia.rds.amazonaws.com
DB_PORT=5432
DB_NAME=mosaforge_enterprise
DB_USER=mosaforge_app
DB_PASSWORD=${DB_MASTER_PASSWORD}

# Read Replicas
DB_READ_HOST=mosaforge-replica.prod.ethiopia.rds.amazonaws.com
DB_READ_PORT=5432
DB_READ_USER=mosaforge_readonly
DB_READ_PASSWORD=${DB_READONLY_PASSWORD}

# Connection Pool Settings
DB_POOL_MIN=5
DB_POOL_MAX=50
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_SSL_REQUIRE=true

# =======================
# 🔐 AUTHENTICATION & SECURITY
# =======================

# JWT Configuration
JWT_SECRET=${JWT_SIGNING_KEY}
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=${JWT_REFRESH_KEY}
JWT_REFRESH_EXPIRES_IN=7d

# Fayda ID Integration
FAYDA_API_BASE_URL=https://api.fayda.gov.et/v1
FAYDA_API_KEY=${FAYDA_PRODUCTION_KEY}
FAYDA_VERIFICATION_ENDPOINT=/identity/verify
FAYDA_DUPLICATE_CHECK_ENDPOINT=/identity/check-duplicate

# OTP Configuration
OTP_SECRET=${OTP_ENCRYPTION_KEY}
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
SMS_OTP_ENABLED=true
EMAIL_OTP_ENABLED=true

# Password Security
BCRYPT_SALT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_ATTEMPTS=5
PASSWORD_LOCKOUT_MINUTES=30

# =======================
# 💰 PAYMENT CONFIGURATION
# =======================

# Revenue Distribution
BUNDLE_PRICE=1999
PLATFORM_REVENUE=1000
EXPERT_REVENUE=999
PAYOUT_SCHEDULE=333,333,333

# Payment Gateways
TELEBIRR_API_URL=https://api.telebirr.et/v1
TELEBIRR_MERCHANT_ID=${TELEBIRR_MERCHANT_ID}
TELEBIRR_PUBLIC_KEY=${TELEBIRR_PUBLIC_KEY_PATH}
TELEBIRR_PRIVATE_KEY=${TELEBIRR_PRIVATE_KEY_PATH}

CBE_BIRR_API_URL=https://api.cbebirr.et/v1
CBE_BIRR_MERCHANT_ID=${CBE_BIRR_MERCHANT_ID}
CBE_BIRR_API_KEY=${CBE_BIRR_API_KEY}
CBE_BIRR_SECRET_KEY=${CBE_BIRR_SECRET_KEY}

# Payment Security
PAYMENT_WEBHOOK_SECRET=${PAYMENT_WEBHOOK_SIGNING_KEY}
PAYMENT_TIMEOUT_MS=30000
PAYMENT_RETRY_ATTEMPTS=3

# =======================
# 🎯 QUALITY SYSTEM CONFIG
# =======================

# Quality Thresholds
QUALITY_MASTER_THRESHOLD=4.7
QUALITY_SENIOR_THRESHOLD=4.3
QUALITY_STANDARD_THRESHOLD=4.0
QUALITY_DEVELOPING_THRESHOLD=3.5
QUALITY_PROBATION_THRESHOLD=3.0

# Performance Bonuses
BONUS_MASTER_PERCENTAGE=20
BONUS_SENIOR_PERCENTAGE=10
BONUS_STANDARD_PERCENTAGE=0
PENALTY_DEVELOPING_PERCENTAGE=10
PENALTY_PROBATION_PERCENTAGE=20

# Capacity Limits
CAPACITY_MASTER_MAX=9999
CAPACITY_SENIOR_MAX=100
CAPACITY_STANDARD_MAX=50
CAPACITY_DEVELOPING_MAX=25
CAPACITY_PROBATION_MAX=10

# =======================
# 📚 LEARNING ENGINE CONFIG
# =======================

# Duolingo-style Engine
EXERCISE_GENERATION_INTERVAL=24
MAX_EXERCISES_PER_DAY=20
MIN_COMPLETION_RATE=0.7
PROGRESS_TRACKING_INTERVAL=3600

# Real-time Charts
FOREX_DATA_PROVIDER=oanda
FOREX_API_KEY=${FOREX_DATA_KEY}
FOREX_UPDATE_INTERVAL=5000
CHART_CACHE_DURATION=300

# =======================
# 🏆 CERTIFICATION CONFIG
# =======================

# Yachi Integration
YACHI_API_BASE_URL=https://api.yachi.et/v1
YACHI_API_KEY=${YACHI_PRODUCTION_KEY}
YACHI_VERIFICATION_ENDPOINT=/providers/verify
YACHI_CERTIFICATE_ENDPOINT=/certificates/issue

# Certificate Settings
CERTIFICATE_EXPIRY_DAYS=1095
CERTIFICATE_RENEWAL_DAYS=90
VERIFICATION_QR_ENABLED=true
DIGITAL_SIGNATURE_KEY=${CERTIFICATE_SIGNING_KEY}

# =======================
# 💾 CACHE & PERFORMANCE
# =======================

# Redis Cluster Configuration
REDIS_URL=redis://${REDIS_USER}:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}
REDIS_HOST=mosaforge-cache.prod.ethiopia.redis.amazonaws.com
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=${REDIS_MASTER_PASSWORD}
REDIS_TLS=true

# Cache TTL Settings
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=1800
CACHE_TTL_LONG=86400
CACHE_TTL_SESSION=3600

# Session Configuration
SESSION_SECRET=${SESSION_ENCRYPTION_KEY}
SESSION_MAX_AGE=86400000
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true

# =======================
# 📧 NOTIFICATIONS & MESSAGING
# =======================

# Email Service (SendGrid)
SENDGRID_API_KEY=${SENDGRID_PRODUCTION_KEY}
EMAIL_FROM=noreply@mosaforge.com
EMAIL_FROM_NAME="Mosa Forge Enterprise"
EMAIL_TEMPLATE_WELCOME=d-abc123-welcome
EMAIL_TEMPLATE_PAYMENT=d-abc124-payment
EMAIL_TEMPLATE_CERTIFICATE=d-abc125-certificate

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=${TWILIO_ACCOUNT_SID}
TWILIO_AUTH_TOKEN=${TWILIO_AUTH_TOKEN}
TWILIO_PHONE_NUMBER=+251911234567
SMS_WEBHOOK_URL=https://api.mosaforge.com/webhooks/sms-status

# Push Notifications
FIREBASE_SERVICE_ACCOUNT=${FIREBASE_CREDENTIALS_PATH}
APNS_KEY_PATH=./certs/apns-prod-key.p8
APNS_KEY_ID=${APNS_KEY_ID}
APNS_TEAM_ID=${APNS_TEAM_ID}

# =======================
# 📊 MONITORING & ANALYTICS
# =======================

# Application Monitoring
NEW_RELIC_LICENSE_KEY=${NEW_RELIC_LICENSE_KEY}
NEW_RELIC_APP_NAME="Mosa Forge Enterprise"
NEW_RELIC_LOG_LEVEL=info

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/mosaforge/application.log
LOG_RETENTION_DAYS=30

# Metrics & Tracing
PROMETHEUS_METRICS_PORT=9090
JAEGER_ENDPOINT=http://jaeger.prod.mosaforge.com:14268
TRACING_SAMPLE_RATE=0.1

# Business Intelligence
MIXPANEL_TOKEN=${MIXPANEL_PRODUCTION_TOKEN}
AMPLITUDE_API_KEY=${AMPLITUDE_PRODUCTION_KEY}
GOOGLE_ANALYTICS_ID=GA1-1234567890

# =======================
# 🔧 MICROSERVICES CONFIG
# =======================

# Service Discovery
CONSUL_HOST=consul.prod.mosaforge.com
CONSUL_PORT=8500
SERVICE_DISCOVERY_ENABLED=true

# API Gateway
GATEWAY_TIMEOUT_MS=30000
GATEWAY_RATE_LIMIT=1000
GATEWAY_CIRCUIT_BREAKER_THRESHOLD=0.5

# Microservices Endpoints
AUTH_SERVICE_URL=http://auth-service.prod.svc.cluster.local:3001
PAYMENT_SERVICE_URL=http://payment-service.prod.svc.cluster.local:3002
EXPERT_SERVICE_URL=http://expert-service.prod.svc.cluster.local:3003
STUDENT_SERVICE_URL=http://student-service.prod.svc.cluster.local:3004
QUALITY_SERVICE_URL=http://quality-service.prod.svc.cluster.local:3005
LEARNING_SERVICE_URL=http://learning-service.prod.svc.cluster.local:3006
TRAINING_SERVICE_URL=http://training-service.prod.svc.cluster.local:3007
CERTIFICATION_SERVICE_URL=http://certification-service.prod.svc.cluster.local:3008
ANALYTICS_SERVICE_URL=http://analytics-service.prod.svc.cluster.local:3009

# =======================
# 🐳 DOCKER & KUBERNETES
# =======================

# Container Configuration
DOCKER_REGISTRY=registry.mosaforge.com
DOCKER_NAMESPACE=mosaforge
KUBERNETES_NAMESPACE=production
CLUSTER_NAME=mosaforge-prod-cluster

# Resource Limits
CONTAINER_MEMORY_LIMIT=512Mi
CONTAINER_CPU_LIMIT=500m
CONTAINER_MEMORY_REQUEST=256Mi
CONTAINER_CPU_REQUEST=200m

# Health Checks
HEALTH_CHECK_TIMEOUT=30
HEALTH_CHECK_INTERVAL=60
HEALTH_CHECK_RETRIES=3
READINESS_CHECK_DELAY=10

# =======================
# ☁️ CLOUD & STORAGE
# =======================

# AWS Configuration
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_S3_BUCKET=mosaforge-prod-assets
AWS_CLOUDFRONT_DISTRIBUTION=ABC123DEF456

# File Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf
UPLOAD_TIMEOUT_MS=300000

# CDN Configuration
CDN_BASE_URL=https://assets.mosaforge.com
CDN_CACHE_DURATION=31536000

# =======================
# 🔐 SECURITY & COMPLIANCE
# =======================

# Encryption Keys
ENCRYPTION_KEY=${DATA_ENCRYPTION_KEY}
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_IV_LENGTH=16

# API Security
API_KEY_HEADER=X-API-Key
API_RATE_LIMIT_PER_MINUTE=60
API_RATE_LIMIT_PER_HOUR=1000

# Compliance Settings
DATA_RETENTION_DAYS=2555
GDPR_COMPLIANCE_ENABLED=true
DATA_ENCRYPTION_AT_REST=true
DATA_ENCRYPTION_IN_TRANSIT=true

# Security Headers
CSP_ENABLED=true
HSTS_ENABLED=true
XSS_PROTECTION_ENABLED=true
CONTENT_TYPE_OPTIONS_ENABLED=true

# =======================
# 🚀 PERFORMANCE & OPTIMIZATION
# =======================

# Database Optimization
QUERY_TIMEOUT_MS=10000
CONNECTION_TIMEOUT_MS=5000
IDLE_TIMEOUT_MS=30000

# Cache Optimization
CACHE_COMPRESSION_ENABLED=true
CACHE_SERIALIZATION=json
CACHE_CLUSTER_MODE=true

# Compression
GZIP_COMPRESSION_LEVEL=6
BROTLI_COMPRESSION_ENABLED=true
COMPRESSION_THRESHOLD=1024

# =======================
# 📱 FRONTEND CONFIGURATION
# =======================

# Mobile App
APP_SCHEME=mosaforge
APP_BUNDLE_ID=com.mosaforge.enterprise
APP_STORE_ID=1234567890
PLAY_STORE_ID=com.mosaforge.enterprise

# Web Dashboard
WEB_BASE_URL=https://app.mosaforge.com
ADMIN_BASE_URL=https://admin.mosaforge.com
DOCS_BASE_URL=https://docs.mosaforge.com

# =======================
# 🔄 BACKGROUND JOBS
# =======================

# Queue Configuration
REDIS_QUEUE_HOST=redis-queue.prod.mosaforge.com
REDIS_QUEUE_PORT=6379
QUEUE_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3

# Scheduled Jobs
CRON_PAYOUT_PROCESSING="0 2 * * *" # Daily at 2 AM
CRON_QUALITY_MONITORING="*/30 * * * *" # Every 30 minutes
CRON_ANALYTICS_GENERATION="0 1 * * *" # Daily at 1 AM
CRON_CLEANUP_JOBS="0 3 * * 0" # Weekly on Sunday at 3 AM

# =======================
# 🎯 BUSINESS RULES
# =======================

# Enrollment Rules
MAX_COURSES_PER_STUDENT=5
COOLING_PERIOD_DAYS=7
AUTO_CANCELLATION_DAYS=30
REFUND_PROCESSING_DAYS=14

# Expert Rules
MIN_RATINGS_FOR_TIER=5
TIER_REVIEW_INTERVAL_DAYS=30
PERFORMANCE_REVIEW_DAYS=90
CAPACITY_REVIEW_INTERVAL_DAYS=7

# Learning Rules
MIN_PROGRESS_PERCENTAGE=5
MAX_INACTIVITY_DAYS=14
COMPLETION_DEADLINE_DAYS=120
EXTENSION_REQUEST_DAYS=7

# =============================================
# 🚨 SENSITIVE VALUES - DO NOT COMMIT
# =============================================

# Database Secrets
DB_MASTER_PASSWORD=
DB_READONLY_PASSWORD=

# JWT Secrets
JWT_SIGNING_KEY=
JWT_REFRESH_KEY=

# Payment Gateway Secrets
TELEBIRR_MERCHANT_ID=
TELEBIRR_PRIVATE_KEY_PATH=
CBE_BIRR_API_KEY=
CBE_BIRR_SECRET_KEY=

# API Keys
FAYDA_PRODUCTION_KEY=
YACHI_PRODUCTION_KEY=
FOREX_DATA_KEY=

# External Service Keys
SENDGRID_PRODUCTION_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Encryption Keys
DATA_ENCRYPTION_KEY=
SESSION_ENCRYPTION_KEY=
CERTIFICATE_SIGNING_KEY=
PAYMENT_WEBHOOK_SIGNING_KEY=

# Monitoring Keys
NEW_RELIC_LICENSE_KEY=
MIXPANEL_PRODUCTION_TOKEN=
AMPLITUDE_PRODUCTION_KEY=

# Cloud Secrets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================
# ✅ ENVIRONMENT VALIDATION
# =============================================

# This file is validated on application startup
# All required variables must be set in production
# Use .env.example for development configuration

