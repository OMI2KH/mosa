# ============================
# 🌍 DATABASE CONFIGURATION
# ============================
DATABASE_URL="postgresql://user:pass@localhost:5432/mosa?schema=public"

# ============================
# 🔐 AUTHENTICATION SECRETS
# ============================
JWT_SECRET="your_super_secret_jwt_key_here_change_me"
REFRESH_SECRET="your_super_secret_refresh_key_here_change_me"

# ============================
# 💰 PAYMENT GATEWAYS
# ============================

# Telebirr (Sandbox / Live)
TELEBIRR_API_URL="https://sandbox.api.telebirr.com"
TELEBIRR_API_KEY="your_telebirr_sandbox_key"

# CBE Birr (Test / Live)
CBEBIRR_API_URL="https://test.cbebirr.com"
CBEBIRR_API_KEY="your_cbebirr_test_key"

# ============================
# 💸 SUBSCRIPTION SETTINGS
# ============================
SUB_PRICE=49   # Subscription price in ETB

# ============================
# 🖥️ FRONTEND CONNECTION
# ============================
FRONTEND_URL="http://localhost:19006"

# ============================
# ⚙️ APP ENVIRONMENT
# ============================
NODE_ENV=development
PORT=4000
