// 🎯 MOSA FORGE: Enterprise Database Schema
// 
// @description Complete Prisma schema for Mosa Forge Enterprise Platform
// @version 1.0.0
// @author Oumer Muktar | Powered by Chereka
//
// 🏗️ ENTERPRISE FEATURES:
// - Complete user management with Fayda ID integration
// - Expert quality tracking and tier system
// - Payment and revenue distribution
// - Learning progress and certification
// - Quality guarantee enforcement

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["filterJson"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🏗️ ENUMS - Enterprise Domain Definitions
enum UserRole {
  STUDENT
  EXPERT
  ADMIN
  QUALITY_MANAGER
  FINANCE_MANAGER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
  INACTIVE
}

enum ExpertTier {
  MASTER
  SENIOR
  STANDARD
  DEVELOPING
  PROBATION
}

enum CoursePhase {
  MINDSET
  THEORY
  HANDS_ON
  CERTIFICATION
  COMPLETED
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  PAUSED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  TELEBIRR
  CBE_BIRR
  BANK_TRANSFER
  CASH
}

enum QualityStatus {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL
}

enum SkillCategory {
  ONLINE_SKILLS
  OFFLINE_SKILLS
  HEALTH_SPORTS
  BEAUTY_FASHION
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum CertificateStatus {
  PENDING
  ISSUED
  VERIFIED
  REVOKED
  EXPIRED
}

// 🏗️ MODELS - Enterprise Data Structure

model User {
  // 🆔 Primary Identifiers
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🔐 Authentication & Identity
  faydaId     String   @unique @db.VarChar(20)
  phoneNumber String   @unique @db.VarChar(15)
  email       String?  @unique
  password    String   @db.VarChar(255)
  
  // 👤 Personal Information
  firstName     String   @db.VarChar(100)
  lastName      String   @db.VarChar(100)
  dateOfBirth   DateTime?
  gender        String?  @db.VarChar(10)
  profileImage  String?  @db.VarChar(500)
  
  // 🏢 Professional Information
  role      UserRole
  status    UserStatus @default(PENDING)
  
  // 📍 Location Information
  region    String? @db.VarChar(100)
  city      String? @db.VarChar(100)
  address   String? @db.VarChar(500)
  
  // 🔒 Security & Verification
  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)
  isFaydaVerified Boolean @default(false)
  verificationToken String?
  resetToken       String?
  
  // 📊 Timestamps
  lastLoginAt DateTime?
  verifiedAt  DateTime?
  
  // 🏗️ Relations
  student      Student?
  expert       Expert?
  admin        Admin?
  payments     Payment[]
  enrollments  Enrollment[]
  ratingsGiven Rating[]
  
  // 🎯 Indexes
  @@index([faydaId, phoneNumber])
  @@map("users")
}

model Student {
  // 🆔 Primary Identifiers
  id     String @id @default(cuid())
  userId String @unique
  
  // 🎓 Student Information
  educationLevel   String? @db.VarChar(100)
  employmentStatus String? @db.VarChar(50)
  incomeRange      String? @db.VarChar(50)
  learningGoals    String? @db.Text
  
  // 📈 Progress Tracking
  totalCoursesCompleted Int      @default(0)
  totalCoursesEnrolled  Int      @default(0)
  averageRating         Float?   @default(0)
  joinedAt             DateTime @default(now())
  
  // 🏗️ Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  assessments MindsetAssessment[]
  
  // 🎯 Indexes
  @@index([userId])
  @@map("students")
}

model Expert {
  // 🆔 Primary Identifiers
  id     String @id @default(cuid())
  userId String @unique
  
  // 🏆 Professional Information
  tier             ExpertTier @default(STANDARD)
  professionalTitle String    @db.VarChar(200)
  yearsOfExperience Int       @default(0)
  bio              String?    @db.Text
  hourlyRate       Float?     @default(0)
  
  // 📊 Capacity Management
  maxStudents     Int @default(25)
  currentStudents Int @default(0)
  isAcceptingNewStudents Boolean @default(true)
  
  // 💰 Financial Information
  totalEarnings    Float   @default(0)
  pendingEarnings  Float   @default(0)
  totalStudentsTaught Int  @default(0)
  
  // 🏢 Business Information
  businessName    String? @db.VarChar(200)
  businessLicense String? @db.VarChar(100)
  taxId          String? @db.VarChar(100)
  
  // 📍 Service Areas
  serviceRegions String[] // JSON array of regions
  
  // 🏗️ Relations
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  expertSkills    ExpertSkill[]
  enrollments     Enrollment[]
  qualityMetrics  QualityMetrics[]
  trainingSessions TrainingSession[]
  certificates    Certificate[]
  payouts         Payout[]
  
  // 🎯 Indexes
  @@index([userId, tier])
  @@index([currentStudents])
  @@map("experts")
}

model ExpertSkill {
  // 🆔 Primary Identifiers
  id       String @id @default(cuid())
  expertId String
  skillId  String
  
  // 🎯 Skill Proficiency
  proficiencyLevel String @db.VarChar(50) // Beginner, Intermediate, Advanced, Expert
  yearsExperience  Int    @default(0)
  isVerified       Boolean @default(false)
  verifiedAt       DateTime?
  
  // 📊 Performance Metrics
  successRate    Float? @default(0)
  studentSatisfaction Float? @default(0)
  
  // 🏗️ Relations
  expert Expert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  skill  Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  // 🎯 Unique Constraint & Indexes
  @@unique([expertId, skillId])
  @@index([expertId, proficiencyLevel])
  @@map("expert_skills")
}

model Skill {
  // 🆔 Primary Identifiers
  id          String @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 🎯 Skill Information
  name        String @db.VarChar(200)
  description String @db.Text
  category    SkillCategory
  icon        String? @db.VarChar(500)
  
  // 📊 Learning Configuration
  theoryExercises     Int @default(100)
  practicalExercises  Int @default(50)
  assessmentExercises Int @default(10)
  estimatedDuration   Int @default(120) // days
  
  // 💰 Pricing & Revenue
  basePrice     Int @default(1999) // 1,999 ETB
  mosaRevenue   Int @default(1000) // 1,000 ETB
  expertRevenue Int @default(999)  // 999 ETB
  
  // 📈 Platform Metrics
  totalEnrollments Int @default(0)
  completionRate   Float? @default(0)
  averageRating    Float? @default(0)
  isActive        Boolean @default(true)
  
  // 🏗️ Relations
  expertSkills  ExpertSkill[]
  enrollments   Enrollment[]
  skillPackages SkillPackage[]
  
  // 🎯 Indexes
  @@unique([name, category])
  @@index([category, isActive])
  @@map("skills")
}

model SkillPackage {
  // 🆔 Primary Identifiers
  id          String @id @default(cuid())
  skillId     String
  createdAt   DateTime @default(now())
  
  // 📦 Package Information
  name        String @db.VarChar(200)
  description String @db.Text
  level       String @db.VarChar(50) // Basic, Intermediate, Advanced, Professional, Master
  
  // 🎯 Learning Content
  exerciseCount Int @default(0)
  durationDays  Int @default(30)
  prerequisites String[] // JSON array of prerequisite package IDs
  
  // 💰 Pricing
  price       Int @default(0) // Additional to base price
  isActive   Boolean @default(true)
  
  // 🏗️ Relations
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  // 🎯 Indexes
  @@index([skillId, level])
  @@map("skill_packages")
}

model Enrollment {
  // 🆔 Primary Identifiers
  id          String @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 🔗 Core Relationships
  studentId   String
  expertId    String
  skillId     String
  paymentId   String?
  
  // 🎯 Enrollment Details
  status      EnrollmentStatus @default(PENDING)
  currentPhase CoursePhase @default(MINDSET)
  startDate   DateTime?
  expectedEndDate DateTime?
  actualEndDate DateTime?
  
  // 💰 Financial Details
  bundlePrice    Int @default(1999)
  mosaRevenue    Int @default(1000)
  expertRevenue  Int @default(999)
  
  // 📊 Progress Tracking
  overallProgress Float @default(0)
  lastActivityAt DateTime?
  
  // 🔍 Tracking & Audit
  traceId      String? @unique
  cancellationReason String? @db.Text
  refundAmount Float? @default(0)
  
  // 🏗️ Relations
  student         Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  expert          Expert          @relation(fields: [expertId], references: [id], onDelete: Cascade)
  skill           Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)
  payment         Payment?        @relation(fields: [paymentId], references: [id])
  learningProgress LearningProgress[]
  trainingSessions TrainingSession[]
  mindsetAssessments MindsetAssessment[]
  certificate     Certificate?
  ratings         Rating[]
  
  // 🎯 Indexes
  @@unique([studentId, skillId, status])
  @@index([expertId, status])
  @@index([studentId, createdAt])
  @@index([traceId])
  @@map("enrollments")
}

model Payment {
  // 🆔 Primary Identifiers
  id          String @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 🔗 Relationships
  userId      String
  enrollment  Enrollment?
  
  // 💰 Payment Information
  amount      Int @default(1999)
  currency    String @default("ETB") @db.VarChar(3)
  status      PaymentStatus @default(PENDING)
  method      PaymentMethod
  
  // 🏦 Payment Gateway Details
  gatewayTransactionId String? @db.VarChar(200)
  gatewayResponse     Json?    // Raw gateway response
  gatewayName         String?  @db.VarChar(50) // telebirr, cbe_birr, etc.
  
  // 💸 Revenue Distribution
  mosaRevenue    Int @default(1000)
  expertRevenue  Int @default(999)
  payoutSchedule Json // 333/333/333 structure
  
  // 📊 Financial Tracking
  paidAt       DateTime?
  refundedAt   DateTime?
  refundAmount Float? @default(0)
  
  // 🔍 Audit & Security
  ipAddress    String? @db.VarChar(45)
  userAgent    String? @db.Text
  metadata     Json?   // Additional payment data
  
  // 🏗️ Relations
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  payouts Payout[]
  
  // 🎯 Indexes
  @@index([userId, status])
  @@index([gatewayTransactionId])
  @@index([createdAt])
  @@map("payments")
}

model Payout {
  // 🆔 Primary Identifiers
  id          String @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 🔗 Relationships
  expertId    String
  paymentId   String?
  enrollmentId String?
  
  // 💰 Payout Information
  amount      Float
  currency    String @default("ETB") @db.VarChar(3)
  status      PaymentStatus @default(PENDING)
  
  // 🎯 Payout Schedule
  payoutPhase String @db.VarChar(50) // START, MIDPOINT, COMPLETION, BONUS
  scheduledDate DateTime?
  paidAt      DateTime?
  
  // 📊 Quality Bonuses
  baseAmount    Float @default(333)
  bonusAmount   Float @default(0)
  penaltyAmount Float @default(0)
  qualityScore  Float? // Score at time of payout
  
  // 🏦 Banking Information
  bankName      String? @db.VarChar(100)
  accountNumber String? @db.VarChar(50)
  accountName   String? @db.VarChar(200)
  
  // 🔍 Tracking
  transactionId String? @unique @db.VarChar(200)
  failureReason String? @db.Text
  
  // 🏗️ Relations
  expert    Expert    @relation(fields: [expertId], references: [id], onDelete: Cascade)
  payment   Payment?  @relation(fields: [paymentId], references: [id])
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id])
  
  // 🎯 Indexes
  @@index([expertId, status])
  @@index([scheduledDate])
  @@map("payouts")
}

model LearningProgress {
  // 🆔 Primary Identifiers
  id           String @id @default(cuid())
  enrollmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // 🎯 Progress Tracking
  phase        CoursePhase
  progress     Float @default(0) // 0-100%
  completedExercises Int @default(0)
  totalExercises     Int @default(0)
  
  // 📊 Performance Metrics
  averageScore Float? @default(0)
  timeSpent    Int?   @default(0) // in minutes
  lastActivity DateTime?
  
  // 🏗️ Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  
  // 🎯 Unique Constraint & Indexes
  @@unique([enrollmentId, phase])
  @@index([enrollmentId, progress])
  @@map("learning_progress")
}

model MindsetAssessment {
  // 🆔 Primary Identifiers
  id           String @id @default(cuid())
  studentId    String
  enrollmentId String
  createdAt    DateTime @default(now())
  
  // 🎯 Assessment Details
  week         Int // 1-4
  topic        String @db.VarChar(200)
  status       String @db.VarChar(50) // PENDING, IN_PROGRESS, COMPLETED
  
  // 📊 Assessment Results
  score        Float?
  totalPoints  Int @default(100)
  completedAt  DateTime?
  
  // 📝 Exercise Data
  exercises    Json // Array of exercise objects
  responses    Json? // Student responses
  
  // 🏗️ Relations
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  
  // 🎯 Indexes
  @@unique([enrollmentId, week])
  @@index([studentId, createdAt])
  @@map("mindset_assessments")
}

model TrainingSession {
  // 🆔 Primary Identifiers
  id           String @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // 🔗 Relationships
  enrollmentId String
  expertId     String
  
  // 🎯 Session Details
  title        String @db.VarChar(200)
  description  String? @db.Text
  status       SessionStatus @default(SCHEDULED)
  type         String @db.VarChar(50) // PRACTICAL, THEORY, ASSESSMENT
  
  // 🗓️ Scheduling
  scheduledDate DateTime
  startTime    DateTime?
  endTime      DateTime?
  duration     Int @default(60) // minutes
  
  // 📍 Location/Virtual
  location     String? @db.VarChar(500)
  meetingLink  String? @db.VarChar(500)
  
  // 📊 Attendance & Feedback
  attendanceVerified Boolean @default(false)
  studentFeedback   String? @db.Text
  expertFeedback    String? @db.Text
  
  // 🏗️ Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  expert     Expert     @relation(fields: [expertId], references: [id], onDelete: Cascade)
  
  // 🎯 Indexes
  @@index([enrollmentId, scheduledDate])
  @@index([expertId, status])
  @@map("training_sessions")
}

model QualityMetrics {
  // 🆔 Primary Identifiers
  id        String @id @default(cuid())
  expertId  String
  createdAt DateTime @default(now())
  validFrom DateTime @default(now())
  validTo   DateTime?
  
  // 📊 Core Quality Metrics
  overallScore      Float @default(0)
  completionRate    Float @default(0) // % of students who complete
  averageRating     Float @default(0) // 1-5 stars
  responseTime      Float @default(24) // hours
  studentSatisfaction Float @default(0) // 0-100%
  
  // 🎯 Detailed Metrics
  technicalCompetence Float @default(0)
  communicationSkills Float @default(0)
  professionalism     Float @default(0)
  punctuality         Float @default(0)
  
  // 📈 Performance Tracking
  totalSessions     Int @default(0)
  completedSessions Int @default(0)
  studentRetention  Float @default(0)
  
  // 🏆 Tier Calculations
  calculatedTier ExpertTier?
  tierProgress   Float? @default(0) // Progress to next tier
  
  // 🔍 Status
  isValid      Boolean @default(true)
  notes        String? @db.Text
  
  // 🏗️ Relations
  expert Expert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  
  // 🎯 Indexes
  @@index([expertId, isValid])
  @@index([overallScore, isValid])
  @@map("quality_metrics")
}

model Rating {
  // 🆔 Primary Identifiers
  id           String @id @default(cuid())
  enrollmentId String
  raterId      String // User who gave the rating
  ratedId      String // User who received the rating (expert or student)
  createdAt    DateTime @default(now())
  
  // ⭐ Rating Details
  score        Int // 1-5
  type         String @db.VarChar(20) // EXPERT_RATING, STUDENT_RATING
  dimension    String @db.VarChar(50) // TECHNICAL, COMMUNICATION, etc.
  
  // 📝 Feedback
  comment      String? @db.Text
  isAnonymous  Boolean @default(false)
  
  // 🏗️ Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  rater      User       @relation(fields: [raterId], references: [id], onDelete: Cascade)
  rated      User       @relation(fields: [ratedId], references: [id], onDelete: Cascade)
  
  // 🎯 Indexes
  @@unique([enrollmentId, raterId, dimension])
  @@index([ratedId, type])
  @@map("ratings")
}

model Certificate {
  // 🆔 Primary Identifiers
  id           String @id @default(cuid())
  enrollmentId String @unique
  expertId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // 🏆 Certificate Information
  certificateNumber String @unique @db.VarChar(100)
  status           CertificateStatus @default(PENDING)
  issuedAt         DateTime?
  verifiedAt       DateTime?
  expiresAt        DateTime?
  
  // 🎓 Certification Details
  skillName    String @db.VarChar(200)
  studentName  String @db.VarChar(200)
  expertName   String @db.VarChar(200)
  finalScore   Float?
  
  // 🔗 Yachi Integration
  yachiVerified   Boolean @default(false)
  yachiProfileId  String? @db.VarChar(100)
  yachiVerifiedAt DateTime?
  
  // 📄 Digital Asset
  pdfUrl       String? @db.VarChar(500)
  qrCodeUrl    String? @db.VarChar(500)
  metadata     Json?   // Additional certificate data
  
  // 🏗️ Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  expert     Expert     @relation(fields: [expertId], references: [id], onDelete: Cascade)
  
  // 🎯 Indexes
  @@index([certificateNumber])
  @@index([yachiVerified])
  @@map("certificates")
}

model PlatformRevenue {
  // 🆔 Primary Identifiers
  id        String @id @default(cuid())
  date      DateTime @unique // Daily aggregation
  createdAt DateTime @default(now())
  
  // 💰 Revenue Breakdown
  totalRevenue       Float @default(0)
  mosaRevenue        Float @default(0)
  expertPayouts      Float @default(0)
  transactionFees    Float @default(0)
  netRevenue         Float @default(0)
  
  // 📊 Enrollment Metrics
  newEnrollments     Int @default(0)
  completedCourses   Int @default(0)
  completionRate     Float @default(0)
  
  // 👥 User Metrics
  newStudents        Int @default(0)
  newExperts         Int @default(0)
  activeUsers        Int @default(0)
  
  // 🎯 Quality Metrics
  averageExpertRating Float @default(0)
  studentSatisfaction Float @default(0)
  
  // 🏗️ Indexes
  @@index([date])
  @@map("platform_revenue")
}

model Admin {
  // 🆔 Primary Identifiers
  id     String @id @default(cuid())
  userId String @unique
  
  // 👨‍💼 Admin Information
  role    UserRole @default(ADMIN)
  department String @db.VarChar(100)
  permissions String[] // JSON array of permissions
  
  // 🏗️ Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("admins")
}

model SystemLog {
  // 🆔 Primary Identifiers
  id        String @id @default(cuid())
  createdAt DateTime @default(now())
  
  // 📝 Log Details
  level     String @db.VarChar(20) // INFO, WARN, ERROR, DEBUG
  service   String @db.VarChar(50)
  action    String @db.VarChar(100)
  message   String @db.Text
  
  // 👤 User Context
  userId    String?
  userRole  UserRole?
  
  // 🔍 Request Context
  ipAddress String? @db.VarChar(45)
  userAgent String? @db.Text
  traceId   String? @db.VarChar(100)
  
  // 📊 Additional Data
  metadata  Json?
  
  // 🎯 Indexes
  @@index([createdAt])
  @@index([service, level])
  @@index([userId])
  @@map("system_logs")
}

model MindsetSchedule {
  // 🆔 Primary Identifiers
  id           String @id @default(cuid())
  enrollmentId String
  createdAt    DateTime @default(now())
  
  // 🗓️ Schedule Information
  week         Int // 1-4
  topic        String @db.VarChar(200)
  scheduledDate DateTime
  status       String @db.VarChar(20) @default(PENDING) // PENDING, ACTIVE, COMPLETED
  
  // 🏗️ Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  
  // 🎯 Indexes
  @@unique([enrollmentId, week])
  @@index([scheduledDate, status])
  @@map("mindset_schedules")
}

// 🏗️ DATABASE CONSTRAINTS & VALIDATIONS

// Custom validation for revenue splits
// mosaicRevenue + expertRevenue must equal bundlePrice
// This is enforced at application level with Prisma middleware

// 🎯 COMPOSITE INDEXES FOR PERFORMANCE
// These are already defined in individual models

// 🏗️ RELATIONSHIP INTEGRITY
// All foreign key relationships use onDelete: Cascade for data consistency
// Unique constraints prevent data duplication

// 📊 ENTERPRISE-READY FEATURES:
// 1. Complete user management with Fayda ID
// 2. Expert quality tracking and tier system
// 3. Payment and revenue distribution (1000/999 split)
// 4. Learning progress tracking across 4 phases
// 5. Quality guarantee enforcement
// 6. Yachi certification integration
// 7. Comprehensive analytics and reporting
// 8. Scalable relationship design
// 9. Audit trails and logging
// 10. Multi-tenancy ready structure